public enum ByteStatus: UInt8, Hashable, Sendable, CaseIterable {
    case idle = 0
    case running = 255

    @usableFromInline init(fromC c: UInt8) { self = ByteStatus(rawValue: c)! }
    @usableFromInline var cValue: UInt8 { rawValue }

}

extension ByteStatus: WireCodable {
    @inlinable static func decode(from reader: inout WireReader) -> ByteStatus { ByteStatus(rawValue: reader.readU8())! }
    @inlinable func encode(to writer: inout WireWriter) { writer.writeU8(rawValue) }
}
